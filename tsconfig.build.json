{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": false,
    "inlineSources": true,
    "noEmit": false,
    "outDir": "dist",
    "rewriteRelativeImportExtensions": true,
    "sourceMap": true
  },
  "include": [
    "bin/**/*.ts",
    "src/**/*.ts"
  ]
}
